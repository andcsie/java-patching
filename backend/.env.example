# Application
APP_NAME="Java Patching Application"
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/javapatching
REDIS_URL=redis://localhost:6379

# Authentication
SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# LLM Providers (configure at least one)
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-pro

# Self-hosted (Ollama or OpenAI-compatible)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Default LLM provider (gemini, openai, anthropic, or ollama)
# Gemini recommended for cost-efficiency
DEFAULT_LLM_PROVIDER=gemini

# Repository storage path
REPOS_BASE_PATH=/app/repos
